    "numeric_fields": ["gross_salary", "net_salary", "income_tax", "stamp_tax", "sgk_employee", "sgk_employer", "bonus", "benefits", "total_employer_cost"],
    "date_fields": ["date"]
  },
  "output_kinds": ["json", "xlsx"],
  "template_version": "1.0",
  "handler_class": "reports.payroll_cost_report.ReportAgent",
  "alternative_reports": ["personnel_expense_report"]
}
